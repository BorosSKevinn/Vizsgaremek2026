@using System.ComponentModel.DataAnnotations
<section class="callback-form" @attributes="AdditionalAttributes">
    <div class="callback-container">

        <header class="section-heading observe-animate fade-slide-in">
            <h2>Kérj <em>visszahívást</em></h2>
            <span>Írd meg röviden, miben segíthetünk – edzőink hamarosan visszahívnak</span>
        </header>

        <form class="callback-card observe-animate bounce-in" action="#" @onsubmit="HandleSubmit" method="post" novalidate>
            <div class="callback-card-accent" aria-hidden="true"></div>

            <div class="form-grid">
                <div class="form-field">
                    <input id="name" name="name" type="text" @bind="form.Name" class="form-input" placeholder=" " required>
                    <label for="name" class="form-label">Teljes Név</label>
                    <span class="form-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M12 12a5 5 0 1 0-5-5 5 5 0 0 0 5 5Zm0 2c-4.42 0-8 2.24-8 5v1h16v-1c0-2.76-3.58-5-8-5Z" /></svg>
                    </span>
                </div>

                <div class="form-field">
                    <input id="email" name="email" type="email" class="form-input" placeholder=" " @bind="form.Email" required>
                    <label for="email" class="form-label">E-Mail Cím</label>
                    <span class="form-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 4-8 5L4 8V6l8 5 8-5Z" /></svg>
                    </span>
                </div>

                <div class="form-field">
                    <input id="subject" name="subject" type="text" class="form-input" placeholder=" " @bind="form.Topic" required>
                    <label for="subject" class="form-label">Tárgy</label>
                    <span class="form-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M10.59 2 2 10.59V22h11.41L22 13.41 10.59 2ZM7 14a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z" /></svg>
                    </span>
                </div>
            </div>

            <div class="form-field form-field-textarea">
                <textarea id="message" name="message" rows="6" class="form-input" placeholder=" " @bind="form.Message" required></textarea>
                <label for="message" class="form-label">Üzenet</label>
                <span class="form-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M21 3H3a2 2 0 0 0-2 2v16l4-4h16a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2Z" /></svg>
                </span>
            </div>

            <div class="consent field-full">
                <input type="checkbox" id="consent" class="checkbox" @bind="form.Consent" />
                <label for="consent">
                    Elfogadom az <a href="/privacy-contact">adatkezelési tájékoztatót</a> *
                </label>
                @if (errors.ContainsKey(nameof(form.Consent)))
                {
                    <span class="val-err">@errors[nameof(form.Consent)]</span>
                }
            </div>

            <div id="turnstile-container" class="turnstile-container">

                <input type="hidden" class="hp" autocomplete="off" tabindex="-1" aria-hidden="true"
                       @bind="form.HoneyPot" placeholder="">

            </div>
            <button type="submit" class="callback-btn" disabled="@isSending">Üzenet Küldése</button>
        </form>

    </div>
</section>

@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

@code {
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }



    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
        }
    }


    private ContactForm form = new();
    private bool isSending;
    private bool sent;
    private bool error;
    private string captchaToken = "";
    private Dictionary<string, string> errors = new();

    private async Task HandleSubmit()
    {
        errors.Clear();

        var ctx = new ValidationContext(form);
        var results = new List<ValidationResult>();
        bool isValid = Validator.TryValidateObject(form, ctx, results, true);
        if (!isValid) { StateHasChanged(); return; }

        if (!string.IsNullOrWhiteSpace(form.HoneyPot))
        {
            sent = true; error = false; return;
        }

        var formApi = new
        {
            form.Name,
            form.Email,
            form.Topic,
            form.Message,
            CaptchaToken = captchaToken
        };

        isSending = true;
        var response = await Http.PostAsJsonAsync("api/contact/submit", formApi);

        if (response.IsSuccessStatusCode)
        {
            captchaToken = "";
            sent = true; error = false; isSending = false;
            form = new();
            StateHasChanged();
            await Task.Delay(1500);
            NavigationManager.NavigateTo("/");
        }
        else
        {
            error = true;
            isSending = false;
        }
    }

    [JSInvokable]
    public void OnCaptchaCompleted(string token)
    {
        captchaToken = token;
        StateHasChanged();
    }


    public class ContactForm
    {
        [Required(ErrorMessage = "Kérlek add meg a neved.")]
        [StringLength(80, ErrorMessage = "A név legfeljebb 80 karakter lehet.")]
        public string? Name { get; set; }

        [Required(ErrorMessage = "Kérlek add meg az email címed.")]
        [EmailAddress(ErrorMessage = "Érvénytelen email formátum.")]
        public string? Email { get; set; }

        public string? Topic { get; set; }

        [Required(ErrorMessage = "Írj pár szót az üzenetbe.")]
        [StringLength(4000, ErrorMessage = "Túl hosszú üzenet (max. 4000 karakter).")]
        public string? Message { get; set; }

        [Range(typeof(bool), "true", "true", ErrorMessage = "Fogadd el az adatkezelési tájékoztatót.")]
        public bool Consent { get; set; }
        public string? HoneyPot { get; set; }
    }
}