        </ul>
    </div>
</div>

@if (!OnlyTop)
{
    <header id="main-header" class="main-header">
        <nav class="navbar">
            <div class="navbar-container">
                <div class="logo-container">
                    <a class="navbar-brand" href="/" aria-label="Fitness Időpontfoglalás">
                        <h2>Fitness időpontfoglalás</h2>
                    </a>
                </div>

                <button class="navbar-toggler"
                        aria-expanded="@menuOpen"
                        aria-controls="navbar-menu"
                        aria-label="Toggle navigation"
                        @onclick="ToggleMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div id="navbar-menu" class="navbar-collapse @(menuOpen ? " open" : "")">
                    <ul class="navbar-nav">
                        <li class="nav-item active">
                            <a class="nav-link" href="#top">Kezdőlap<span class="sr-only">(aktuális)</span></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#services">Szolgáltatások</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#stats">Eredmények</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#about">Rólunk</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#contact">Kapcsolat</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link rent-link" href="/rental">Időpont</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
}

@inject IJSRuntime JS
@code {
    [Parameter]
    public bool OnlyTop { get; set; } = false;

    private bool menuOpen;
    private void ToggleMenu() => menuOpen = !menuOpen;


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("navbarScrollInit");
            await JS.InvokeVoidAsync("navSpyInit");
        }
    }
}
